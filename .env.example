# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=openseedr
DB_NAME=openseedr
DB_PASSWORD=changeme

# ── JWT — generate with: openssl rand -hex 32 ─────────────────────────────────
JWT_SECRET=replace_me_with_a_long_random_string_at_least_32_chars

# ── qBittorrent ───────────────────────────────────────────────────────────────
QBT_USER=admin
QBT_PASS=changeme

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
CORS_ORIGIN=http://localhost

# ── OAuth — leave blank to disable ────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost/api/v1/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost/api/v1/auth/github/callback

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme
